ARG OPENCLAW_IMAGE=openclaw:local
FROM ${OPENCLAW_IMAGE}

# Install Claude Code CLI (npm global for node user)
RUN npm install -g --prefix /home/node/.local @anthropic-ai/claude-code

ENV PATH="/home/node/.local/bin:${PATH}"

